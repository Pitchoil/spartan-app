# ── Binary files ────────────────────────────────────────────────────
# Prevents git from rewriting bytes via line-ending conversion.
# PNG/image corruption ("improper image header") in CI is caused by
# git treating these as text.  This file fixes that permanently.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.eot     binary
*.apk     binary
*.aab     binary
*.keystore binary
*.jks     binary

# ── Text files — normalise to LF everywhere ──────────────────────────
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.xml     text eol=lf
*.gradle  text eol=lf
*.properties text eol=lf
*.txt     text eol=lf
